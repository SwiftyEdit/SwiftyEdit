{
  "name": "swiftyedit/swiftyedit",
  "type": "project",
  "description": "SwiftyEdit is a Web Content Management System for Websites, Blogs and Shops",
  "homepage": "https://swiftyedit.org",
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "SwiftyEdit Developer",
      "role": "Developer",
      "homepage": "https://github.com/SwiftyEdit/SwiftyEdit"
    }
  ],
  "config": {
    "preferred-install": "dist",
    "sort-packages": true,
    "platform": {
      "php": "8.3"
    },
    "vendor-dir": "vendor"
  },
  "require": {
    "ext-pdo": "*",
    "catfan/medoo": "^2.1.12",
    "erusev/parsedown": "1.7.4",
    "erusev/parsedown-extra": "^0.8.1",
    "ezyang/htmlpurifier": "^v4.18.0",
    "guzzlehttp/guzzle": "^7.12.3",
    "league/iso3166": "^4.4.0",
    "mustangostang/spyc": "^0.6.3",
    "paypal/paypal-server-sdk": "^2.3",
    "phpmailer/phpmailer": "^v6.10.0",
    "smarty/smarty": "^v5.8.2",
    "twig/twig": "^3.0"
  },
  "scripts": {
    "buildclean": "rm -rf dist && rm -f ./dist/*.zip",
    "buildprepare": "bash build_prepare.sh",
    "build": [
      "@buildclean",
      "@buildprepare"
    ],
    "audit": "composer audit",
    "outdated": "composer outdated",
    "outdated:direct": "composer outdated --direct",
    "licenses": "composer licenses",
    "validate": "composer validate --strict",
    "check": [
      "@audit",
      "@validate"
    ]
  }
}
